{
  "suiteName": "Basic Operations",
  "tests": [
    {
      "name": "Add two numbers",
      "operation": "Add",
      "parameters": [ 3, 5 ],
      "expectedResult": 8
    },
    {
      "name": "Add multiple numbers",
      "operation": "Add",
      "parameters": [ 1, 2, 3, 4, 5 ],
      "expectedResult": 15
    },
    {
      "name": "Subtract positive result",
      "operation": "Subtract",
      "parameters": [ 10, 4 ],
      "expectedResult": 6
    },
    {
      "name": "Subtract negative result",
      "operation": "Subtract",
      "parameters": [ 3, 7 ],
      "expectedResult": -4
    },
    {
      "name": "Multiply two numbers",
      "operation": "Multiply",
      "parameters": [ 6, 7 ],
      "expectedResult": 42
    },
    {
      "name": "Multiply multiple numbers",
      "operation": "Multiply",
      "parameters": [ 2, 3, 4 ],
      "expectedResult": 24
    },
    {
      "name": "Divide even",
      "operation": "Divide",
      "parameters": [ 10, 2 ],
      "expectedResult": 5.0
    },
    {
      "name": "Divide with decimal result",
      "operation": "Divide",
      "parameters": [ 7, 2 ],
      "expectedResult": 3.5
    }
  ]
}