{
  "suiteName": "Edge Cases & Special Operations",
  "tests": [
    {
      "name": "Divide by zero (expects exception)",
      "operation": "Divide",
      "parameters": [ 10, 0 ],
      "expectedResult": 0,
      "expectException": true,
      "expectedExceptionMessage": "Cannot divide by zero"
    },
    {
      "name": "SquareRoot of perfect square",
      "operation": "SquareRoot",
      "parameters": [ 25 ],
      "expectedResult": 5.0
    },
    {
      "name": "SquareRoot with decimal precision",
      "operation": "SquareRoot",
      "parameters": [ 2 ],
      "expectedResult": 1.4142135623730951
    },
    {
      "name": "SquareRoot of negative (expects exception)",
      "operation": "SquareRoot",
      "parameters": [ -9 ],
      "expectedResult": 0,
      "expectException": true,
      "expectedExceptionMessage": "Cannot calculate square root of a negative number"
    },
    {
      "name": "Power integer exponent",
      "operation": "Power",
      "parameters": [ 2, 10 ],
      "expectedResult": 1024
    },
    {
      "name": "Power with decimal base",
      "operation": "Power",
      "parameters": [ 2.5, 2 ],
      "expectedResult": 6.25
    },
    {
      "name": "Power zero exponent",
      "operation": "Power",
      "parameters": [ 99, 0 ],
      "expectedResult": 1
    },
    {
      "name": "Add with zero",
      "operation": "Add",
      "parameters": [ 0, 0, 0 ],
      "expectedResult": 0
    },
    {
      "name": "Multiply by zero",
      "operation": "Multiply",
      "parameters": [ 5, 0 ],
      "expectedResult": 0
    }
  ]
}